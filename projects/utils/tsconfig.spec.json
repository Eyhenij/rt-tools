{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "module": "commonjs",
    "target": "es2016",
    "types": ["jest", "node"],
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@rt-tools/core": ["../core/src/index.ts"],
      "@angular/cdk/overlay": ["../../node_modules/@angular/cdk/types/overlay.d.ts"],
      "@angular/cdk/*": ["../../node_modules/@angular/cdk/types/*.d.ts"],
      "@angular/core/testing": ["../../node_modules/@angular/core/types/testing.d.ts"],
      "@angular/platform-browser/testing": ["../../node_modules/@angular/platform-browser/types/testing.d.ts"]
    }
  },
  "files": ["src/test-setup.ts"],
  "include": ["jest.config.ts", "src/**/*.test.ts", "src/**/*.spec.ts", "src/**/*.d.ts"]
}
