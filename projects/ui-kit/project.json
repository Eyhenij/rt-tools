{
  "name": "@rt-tools/ui-kit",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "projects/ui-kit/src",
  "prefix": "rt",
  "implicitDependencies": ["@rt-tools/core", "@rt-tools/store", "@rt-tools/utils"],
  "generators": {
    "@schematics/angular:component": {
      "style": "scss",
      "changeDetection": "OnPush"
    }
  },
  "targets": {
    "build": {
      "executor": "@nx/angular:package",
      "options": {
        "project": "projects/ui-kit/ng-package.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "projects/ui-kit/tsconfig.lib.prod.json"
        },
        "development": {
          "tsConfig": "projects/ui-kit/tsconfig.lib.json"
        }
      },
      "defaultConfiguration": "production",
      "outputs": ["{workspaceRoot}/dist/ui-kit"]
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "cacheable": false
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "projects/ui-kit/jest.config.ts"
      }
    },
    "storybook": {
      "executor": "@storybook/angular:start-storybook",
      "options": {
        "port": 6006,
        "configDir": "projects/ui-kit/.storybook",
        "browserTarget": "@rt-tools/ui-kit:build-storybook",
        "compodoc": false,
        "styles": ["projects/ui-kit/.storybook/storybook.scss"]
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "build-storybook": {
      "executor": "@storybook/angular:build-storybook",
      "outputs": ["{options.outputDir}"],
      "options": {
        "outputDir": "dist/storybook/@rt-tools/ui-kit",
        "configDir": "projects/ui-kit/.storybook",
        "browserTarget": "@rt-tools/ui-kit:build-storybook",
        "compodoc": false,
        "styles": ["projects/ui-kit/.storybook/storybook.scss"]
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "nx-release-publish": {
      "dependsOn": ["build"],
      "options": {
        "packageRoot": "{workspaceRoot}/dist/ui-kit"
      }
    },
    "test-storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "test-storybook -c projects/ui-kit/.storybook --url=http://localhost:4400"
      }
    },
    "static-storybook": {
      "executor": "@nx/web:file-server",
      "dependsOn": ["build-storybook"],
      "options": {
        "buildTarget": "@rt-tools/ui-kit:build-storybook",
        "staticFilePath": "dist/storybook/@rt-tools/ui-kit",
        "spa": true,
        "styles": ["projects/ui-kit/.storybook/storybook.scss"]
      },
      "configurations": {
        "ci": {
          "buildTarget": "@rt-tools/ui-kit:build-storybook:ci"
        }
      }
    }
  }
}
