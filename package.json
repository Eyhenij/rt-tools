{
  "name": "@rt/tools",
  "version": "0.0.13",
  "type": "module",
  "scripts": {
    "ng": "nx",
    "build:core": "rimraf dist/core && nx build @rt-tools/core --verbose",
    "build:store": "rimraf dist/store && nx build @rt-tools/store --verbose",
    "build:utils": "rimraf dist/utils && nx build @rt-tools/utils --verbose",
    "build:tools": "rimraf dist/tools && nx build @rt-tools/tools --verbose",
    "build:all": "pnpm run build:core && pnpm run build:store && pnpm run build:utils && pnpm run build:tools",
    "watch": "nx build --watch --configuration development",
    "test": "pnpx nx run-many -t test",
    "lint": "pnpx nx run-many --target=lint --all",
    "prettier": "npx prettier --write ./projects",
    "check:all": "pnpm exec nx run-many -t lint test build --all --parallel",
    "check:affected": "pnpm exec nx affected -t lint test build --parallel",
    "packagr:core": "cd ./dist/core && npm pack && npm publish --access public",
    "packagr:store": "cd ./dist/store && npm pack && npm publish --access public",
    "packagr:utils": "cd ./dist/utils && npm pack && npm publish --access public",
    "packagr:ui-kit": "cd ./dist/tools && npm pack && npm publish --access public",
    "storybook": "nx run @rt-tools/tools:storybook --verbose",
    "build-storybook": "nx run @rt-tools/tools:build-storybook --verbose",
    "graph": "pnpx nx dep-graph",
    "changelog:core": "conventional-changelog -p angular -i projects/core/CHANGELOG.md -s -k projects/core/package.json --commit-path projects/core",
    "changelog:store": "conventional-changelog -p angular -i projects/store/CHANGELOG.md -s -k projects/store/package.json --commit-path projects/store",
    "changelog:utils": "conventional-changelog -p angular -i projects/utils/CHANGELOG.md -s -k projects/utils/package.json --commit-path projects/utils",
    "changelog:tools": "conventional-changelog -p angular -i projects/tools/CHANGELOG.md -s -k projects/tools/package.json --commit-path projects/tools",
    "prepare": "husky",
    "postinstall": "rimraf .angular .nx",
    "preinstall": "npx only-allow pnpm"
  },
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/Eyhenij/rt-tools"
  },
  "keywords": [
    "Angular",
    "Tools",
    "UI-Kit",
    "Utils"
  ],
  "license": "Apache-2.0",
  "workspaces": [
    "projects/core",
    "projects/store",
    "projects/utils",
    "projects/tools"
  ],
  "dependencies": {
    "@floating-ui/dom": "^1.7.4",
    "ngx-image-cropper": "^9.1.5"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "21.0.1",
    "@angular-devkit/core": "21.0.1",
    "@angular-devkit/schematics": "^21.0.1",
    "@angular-eslint/builder": "^21.0.1",
    "@angular-eslint/eslint-plugin": "^21.0.1",
    "@angular-eslint/eslint-plugin-template": "^21.0.1",
    "@angular-eslint/schematics": "^21.0.1",
    "@angular-eslint/template-parser": "^21.0.1",
    "@angular/animations": "21.0.1",
    "@angular/cdk": "21.0.1",
    "@angular/cli": "^21.0.1",
    "@angular/common": "21.0.1",
    "@angular/compiler": "21.0.1",
    "@angular/compiler-cli": "21.0.1",
    "@angular/core": "21.0.1",
    "@angular/forms": "21.0.1",
    "@angular/material": "21.0.1",
    "@angular/platform-browser": "21.0.1",
    "@angular/platform-browser-dynamic": "21.0.1",
    "@angular/router": "21.0.1",
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-angular": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.1",
    "@faker-js/faker": "^10.1.0",
    "@nx/angular": "22.1.3",
    "@nx/eslint-plugin": "22.1.3",
    "@nx/jest": "22.1.3",
    "@nx/js": "22.1.3",
    "@nx/storybook": "22.1.3",
    "@nx/web": "22.1.3",
    "@nx/workspace": "22.1.3",
    "@schematics/angular": "^21.0.1",
    "@storybook/angular": "10.1.2",
    "@swc-node/register": "~1.9.1",
    "@swc/core": "~1.5.7",
    "@swc/helpers": "~0.5.11",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "@typescript-eslint/utils": "^8.40.0",
    "angular-eslint": "^20.3.0",
    "autoprefixer": "^10.4.0",
    "conventional-changelog-cli": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-html": "^8.1.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-preset-angular": "^15.0.3",
    "jest-util": "^29.7.0",
    "jsonc-eslint-parser": "^2.1.0",
    "lint-staged": "^16.2.7",
    "ng-packagr": "^21.0.0",
    "nx": "22.1.3",
    "postcss": "^8.4.5",
    "postcss-url": "~10.1.3",
    "prettier": "^3.7.3",
    "prettier-eslint": "^16.4.2",
    "prettier-plugin-organize-attributes": "^1.0.0",
    "prettier-stylelint": "^0.4.2",
    "rimraf": "^6.1.2",
    "rxjs": "^7.8.2",
    "storybook": "^10.1.2",
    "stylelint": "^16.26.1",
    "stylelint-config-idiomatic-order": "^10.0.0",
    "stylelint-config-standard": "^39.0.1",
    "stylelint-prettier": "^5.0.3",
    "stylelint-scss": "^6.12.1",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "5.9.3",
    "verdaccio": "^6.0.5"
  },
  "lint-staged": {
    "**/src/**/*.{js,ts}": "eslint --fix",
    "**/src/**/*.{js,ts,json,mdx,md,html,scss,css}": "prettier . --write"
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.11.0"
  },
  "nx": {
    "includedScripts": []
  }
}
